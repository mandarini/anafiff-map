# Copy this file to .env.local and fill in real values.
# .env.local is gitignored; .env.local.example is committed as the template.

# Google Maps Platform
# - Cloud Console > APIs & Services > Credentials > API key
# - Enable: Maps JavaScript API
# - Restrict the key by HTTP referrer + the Map ID below
VITE_GOOGLE_MAPS_API_KEY=

# Google Maps Map ID (cloud-styled vector map)
# - Cloud Console > Google Maps Platform > Map Management > Create new Map ID
# - Map type: JavaScript, Vector. Attach a custom style.
VITE_GOOGLE_MAPS_MAP_ID=

# Supabase
# - Project Settings > API > Project URL
VITE_SUPABASE_URL=

# - Project Settings > API > Project API keys > anon / public
VITE_SUPABASE_ANON_KEY=
